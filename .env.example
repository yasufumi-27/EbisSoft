# ── EbisSoft 環境変数のサンプル ──────────────────────────────
# このファイルを .env.local にコピーして値を設定してください。
#   cp .env.example .env.local

# 本番サイトの公開URL（末尾スラッシュなし）。
# canonical / OG画像 / sitemap / robots / 構造化データ の絶対URL生成に使用します。
NEXT_PUBLIC_SITE_URL=https://www.ebissoft.co.jp

# Google Search Console のサイト所有権確認トークン（任意）。
# 設定すると <meta name="google-site-verification"> が出力されます。
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
